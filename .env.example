# .env.example — copy to .env (git-ignored) and fill in your values.
#
#   cp .env.example .env
#
# docker compose auto-loads .env and substitutes ${VAR} into
# docker-compose.yml. Unset vars fall back to the ":-" defaults there.

LLM_BASE_URL=      # OpenAI-compatible endpoint, e.g. https://host/v1
LLM_MODEL=         # model name at that endpoint
LLM_API_KEY=       # bearer token for that endpoint

NIM_API_KEY=       # bearer token for the ASR NIM (optional)
ADMIN_TOKEN=       # shared secret for the Admin tab (optional)
